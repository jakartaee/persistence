<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_4_0.xsd"
             version="4.0">
    <persistence-unit name="JPATCK" transaction-type="RESOURCE_LOCAL">
        <description>Persistence Unit for Jakarta Persistence 4.0 default fetch type tests</description>
        <class>ee.jakarta.tck.persistence.jpa40.fetchdefaults.DefaultFetchBook</class>
        <class>ee.jakarta.tck.persistence.jpa40.fetchdefaults.DefaultFetchPublisher</class>
        <class>ee.jakarta.tck.persistence.jpa40.fetchdefaults.DefaultFetchCover</class>
        <default-to-one-fetch-type>LAZY</default-to-one-fetch-type>
    </persistence-unit>
    <persistence-unit name="JPATCK2" transaction-type="RESOURCE_LOCAL">
        <description>Persistence Unit for Jakarta Persistence 4.0 default fetch type tests</description>
        <class>ee.jakarta.tck.persistence.jpa40.fetchdefaults.DefaultFetchBook</class>
        <class>ee.jakarta.tck.persistence.jpa40.fetchdefaults.DefaultFetchPublisher</class>
        <class>ee.jakarta.tck.persistence.jpa40.fetchdefaults.DefaultFetchCover</class>
        <default-to-one-fetch-type>EAGER</default-to-one-fetch-type>
    </persistence-unit>
</persistence>
